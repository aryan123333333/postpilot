generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

/* ────────────────────── Auth (NextAuth) ────────────────────── */

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("user") // "user" | "admin"
  plan          String    @default("free") // "free" | "pro" | "enterprise"
  credits       Int       @default(20) // credits remaining (deducted per generation)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
  generations   Generation[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

/* ────────────────────── Analytics & History ────────────────────── */

model Generation {
  id              String   @id @default(cuid())
  userId          String?
  topic           String
  platform        String
  tone            String
  postCount       Int      @default(1)
  postsGenerated  Int      @default(0)
  mode            String   @default("generate") // "generate" | "repurpose" | "enhance"
  postsJson       String?  // store generated posts as JSON
  ip              String?
  createdAt       DateTime @default(now())

  user            User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([platform])
  @@index([createdAt])
}

model RateLimitLog {
  id        String   @id @default(cuid())
  ip        String
  createdAt DateTime @default(now())

  @@index([ip, createdAt])
}

model SystemMetric {
  id        String   @id @default(cuid())
  metric    String   @unique // e.g. "totalGenerations", "uptimeStart"
  value     String   @db.Text
  updatedAt DateTime @updatedAt
}
